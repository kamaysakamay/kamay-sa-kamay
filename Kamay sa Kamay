<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kamay sa Kamay — Hand in Hand</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --sun: #F5A623;
    --sky: #1A6FB5;
    --red: #CE1126;
    --dark: #1a1a2e;
    --light: #fdf9f4;
    --gray: #6b7280;
    --card: #ffffff;
    --radius: 16px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Inter',sans-serif; background:var(--light); color:var(--dark); }

  /* HERO */
  .hero {
    position:relative;
    min-height:100vh;
    display:flex; flex-direction:column; justify-content:flex-end;
    overflow:hidden;
  }
  .hero-slider { position:absolute; inset:0; }
  .hero-slide {
    position:absolute; inset:0;
    background-size:cover; background-position:center;
    opacity:0; transition:opacity 1.2s ease;
  }
  .hero-slide.active { opacity:1; }
  .hero-overlay {
    position:absolute; inset:0;
    background:linear-gradient(to top, rgba(26,26,46,0.92) 0%, rgba(26,26,46,0.3) 60%, transparent 100%);
  }
  .hero-content {
    position:relative; z-index:2;
    padding:3rem 2rem 4rem;
    max-width:800px; margin:0 auto; width:100%;
    text-align:center;
  }
  .hero-flag { display:flex; gap:6px; justify-content:center; margin-bottom:1.5rem; }
  .flag-stripe {
    width:28px; height:6px; border-radius:3px;
  }
  .hero-content h1 {
    font-family:'Playfair Display',serif;
    font-size:clamp(2.8rem,8vw,5.5rem);
    color:#fff; line-height:1.05;
    letter-spacing:-0.02em;
    text-shadow:0 2px 20px rgba(0,0,0,0.4);
  }
  .hero-content h1 span { color:var(--sun); }
  .hero-subtitle {
    margin-top:1rem;
    font-size:1.15rem; color:rgba(255,255,255,0.85);
    font-weight:400; line-height:1.6;
  }
  .hero-dots {
    display:flex; gap:8px; justify-content:center; margin-top:1.5rem;
  }
  .dot {
    width:8px; height:8px; border-radius:50%;
    background:rgba(255,255,255,0.4); cursor:pointer; transition:all 0.3s;
  }
  .dot.active { background:var(--sun); transform:scale(1.3); }

  /* LANG SWITCHER */
  .lang-bar {
    background:var(--dark);
    display:flex; justify-content:center; gap:8px;
    padding:0.6rem 1rem;
    position:sticky; top:0; z-index:100;
    box-shadow:0 2px 12px rgba(0,0,0,0.2);
  }
  .lang-btn {
    padding:0.35rem 1rem; border-radius:20px; border:none;
    font-size:0.8rem; font-weight:600; cursor:pointer;
    background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.6);
    transition:all 0.2s;
  }
  .lang-btn.active {
    background:var(--sun); color:var(--dark);
  }

  /* SECTIONS */
  .section { padding:4rem 1.5rem; max-width:900px; margin:0 auto; }
  .section-title {
    font-family:'Playfair Display',serif;
    font-size:clamp(1.8rem,5vw,2.8rem);
    color:var(--dark); margin-bottom:0.5rem;
  }
  .section-title span { color:var(--sky); }
  .divider {
    width:60px; height:4px; border-radius:2px;
    background:linear-gradient(90deg,var(--sky),var(--sun));
    margin-bottom:2rem;
  }

  /* STORY */
  .story-text {
    font-size:1.1rem; line-height:1.9; color:#374151;
  }
  .story-text p { margin-bottom:1rem; }
  .story-text strong { color:var(--sky); }

  /* GOALS */
  .goals-grid { display:grid; gap:1.5rem; }
  @media(min-width:600px){ .goals-grid{ grid-template-columns:1fr 1fr; } }

  .goal-card {
    background:var(--card); border-radius:var(--radius);
    padding:2rem; box-shadow:0 4px 24px rgba(0,0,0,0.08);
    border-top:5px solid var(--sky);
    transition:transform 0.2s;
  }
  .goal-card:hover { transform:translateY(-4px); }
  .goal-card.children { border-top-color:var(--sun); }

  .goal-icon { font-size:2.5rem; margin-bottom:0.75rem; }
  .goal-title { font-family:'Playfair Display',serif; font-size:1.4rem; margin-bottom:0.4rem; }
  .goal-desc { font-size:0.9rem; color:var(--gray); line-height:1.6; margin-bottom:1.5rem; }

  .progress-wrap { margin-bottom:1rem; }
  .progress-label {
    display:flex; justify-content:space-between;
    font-size:0.8rem; font-weight:600; margin-bottom:6px;
    color:var(--gray);
  }
  .progress-bar-bg {
    background:#e5e7eb; border-radius:99px; height:10px; overflow:hidden;
  }
  .progress-bar-fill {
    height:100%; border-radius:99px;
    background:linear-gradient(90deg,var(--sky),#38bdf8);
    transition:width 1.5s ease;
  }
  .goal-card.children .progress-bar-fill {
    background:linear-gradient(90deg,var(--sun),#fbbf24);
  }
  .progress-amount {
    font-size:1.3rem; font-weight:700; color:var(--dark); margin-top:0.5rem;
  }
  .progress-need {
    font-size:0.8rem; color:var(--red); font-weight:600;
  }

  /* DONATE SECTION */
  .donate-section {
    background:linear-gradient(135deg,var(--sky) 0%,#1a3a6e 100%);
    padding:4rem 1.5rem; color:white;
  }
  .donate-inner { max-width:700px; margin:0 auto; text-align:center; }
  .donate-inner h2 {
    font-family:'Playfair Display',serif;
    font-size:clamp(1.8rem,5vw,2.8rem); margin-bottom:0.5rem;
  }
  .donate-inner p { opacity:0.85; margin-bottom:2rem; line-height:1.7; }

  .goal-select {
    display:flex; gap:10px; justify-content:center; flex-wrap:wrap;
    margin-bottom:1.5rem;
  }
  .goal-select-btn {
    padding:0.6rem 1.4rem; border-radius:25px;
    border:2px solid rgba(255,255,255,0.4);
    background:transparent; color:white;
    font-weight:600; cursor:pointer; transition:all 0.2s; font-size:0.9rem;
  }
  .goal-select-btn.active {
    background:var(--sun); border-color:var(--sun); color:var(--dark);
  }

  .amount-grid {
    display:flex; gap:10px; flex-wrap:wrap; justify-content:center;
    margin-bottom:1.5rem;
  }
  .amount-btn {
    width:90px; padding:0.7rem; border-radius:12px;
    border:2px solid rgba(255,255,255,0.3);
    background:rgba(255,255,255,0.1); color:white;
    font-size:1rem; font-weight:700; cursor:pointer; transition:all 0.2s;
  }
  .amount-btn:hover, .amount-btn.selected {
    background:var(--sun); border-color:var(--sun); color:var(--dark);
  }
  .custom-amount {
    display:flex; gap:10px; justify-content:center; align-items:center;
    margin-bottom:2rem;
  }
  .custom-input {
    padding:0.7rem 1rem; border-radius:10px;
    border:2px solid rgba(255,255,255,0.3);
    background:rgba(255,255,255,0.15); color:white;
    font-size:1rem; width:160px; text-align:center;
    outline:none;
  }
  .custom-input::placeholder { color:rgba(255,255,255,0.5); }
  .custom-input:focus { border-color:var(--sun); }

  .donate-btn {
    display:inline-block; padding:1rem 2.5rem;
    background:var(--sun); color:var(--dark);
    font-weight:800; font-size:1.1rem; border-radius:50px;
    text-decoration:none; cursor:pointer; border:none;
    box-shadow:0 8px 30px rgba(245,166,35,0.5);
    transition:transform 0.2s, box-shadow 0.2s;
    letter-spacing:0.02em;
  }
  .donate-btn:hover { transform:translateY(-2px); box-shadow:0 12px 40px rgba(245,166,35,0.6); }
  .paypal-note { font-size:0.75rem; opacity:0.6; margin-top:1rem; }

  /* PHOTO GALLERY */
  .gallery {
    display:grid; gap:10px;
    grid-template-columns: repeat(3,1fr);
  }
  .gallery img {
    width:100%; aspect-ratio:1; object-fit:cover;
    border-radius:10px; transition:transform 0.3s;
  }
  .gallery img:hover { transform:scale(1.03); }
  .gallery img:first-child { grid-column:span 2; aspect-ratio:16/9; }

  /* SHARE */
  .share-section { text-align:center; padding:3rem 1.5rem; background:#fff; }
  .share-section h2 { font-family:'Playfair Display',serif; font-size:1.8rem; margin-bottom:0.5rem; }
  .share-section p { color:var(--gray); margin-bottom:1.5rem; }
  .share-btns { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; }
  .share-btn {
    padding:0.65rem 1.4rem; border-radius:25px; border:none;
    font-weight:600; font-size:0.9rem; cursor:pointer;
    transition:opacity 0.2s; color:white;
  }
  .share-btn:hover { opacity:0.85; }
  .share-fb { background:#1877f2; }
  .share-wa { background:#25d366; }
  .share-tw { background:#000; }
  .share-copy { background:var(--gray); }

  /* COMMUNITY */
  .community-section { padding:4rem 1.5rem; max-width:900px; margin:0 auto; }
  .comments-list { display:grid; gap:1rem; margin-bottom:2rem; }
  .comment-card {
    background:#fff; border-radius:var(--radius);
    padding:1.2rem 1.5rem;
    box-shadow:0 2px 12px rgba(0,0,0,0.06);
    border-left:4px solid var(--sky);
  }
  .comment-card .name { font-weight:700; font-size:0.9rem; color:var(--sky); }
  .comment-card .date { font-size:0.75rem; color:var(--gray); margin-bottom:0.4rem; }
  .comment-card .text { font-size:0.95rem; color:#374151; line-height:1.6; }

  .comment-form { background:#fff; border-radius:var(--radius); padding:2rem; box-shadow:0 4px 20px rgba(0,0,0,0.07); }
  .form-row { display:grid; gap:1rem; margin-bottom:1rem; }
  @media(min-width:500px){ .form-row { grid-template-columns:1fr 1fr; } }
  .form-input, .form-textarea {
    padding:0.75rem 1rem; border-radius:10px;
    border:2px solid #e5e7eb; font-family:inherit; font-size:0.95rem;
    outline:none; width:100%; transition:border 0.2s;
  }
  .form-input:focus, .form-textarea:focus { border-color:var(--sky); }
  .form-textarea { min-height:100px; resize:vertical; }
  .submit-btn {
    padding:0.8rem 2rem; background:var(--sky); color:#fff;
    border:none; border-radius:25px; font-weight:700;
    cursor:pointer; transition:opacity 0.2s; font-size:0.95rem;
  }
  .submit-btn:hover { opacity:0.85; }

  /* FOOTER */
  footer {
    background:var(--dark); color:rgba(255,255,255,0.6);
    text-align:center; padding:2rem 1rem; font-size:0.85rem;
  }
  footer strong { color:var(--sun); }

  /* Translations hidden by default */
  [data-lang] { display:none; }
  [data-lang="en"] { display:block; }
  span[data-lang] { display:none; }
  span[data-lang="en"] { display:inline; }
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-slider" id="slider">
    <div class="hero-slide active" style="background-image:url('data:image/jpeg;base64,')"></div>
    <div class="hero-slide " style="background-image:url('data:image/jpeg;base64,')"></div>
    <div class="hero-slide " style="background-image:url('data:image/jpeg;base64,')"></div>
    <div class="hero-slide " style="background-image:url('data:image/jpeg;base64,')"></div>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-flag">
      <div class="flag-stripe" style="background:#CE1126;"></div>
      <div class="flag-stripe" style="background:#1A6FB5;"></div>
      <div class="flag-stripe" style="background:#F5A623;"></div>
    </div>
    <h1>Kamay sa Kamay<br><span>Hand in Hand</span></h1>
    <p class="hero-subtitle">
      <span data-lang="en">Together, we lift the Philippines — one family, one child, one life at a time.</span>
      <span data-lang="fil">Sama-sama nating iangat ang Pilipinas — isang pamilya, isang bata, isang buhay sa isang pagkakataon.</span>
      <span data-lang="ar">معاً نرفع الفلبين — عائلةً واحدة، وطفلاً واحداً، وحياةً واحدة في كل مرة.</span>
    </p>
    <div class="hero-dots" id="dots">
      <div class="dot active" onclick="goSlide(0)"></div>
      <div class="dot" onclick="goSlide(1)"></div>
      <div class="dot" onclick="goSlide(2)"></div>
      <div class="dot" onclick="goSlide(3)"></div>
    </div>
  </div>
</section>

<!-- LANG BAR -->
<div class="lang-bar">
  <button class="lang-btn active" onclick="setLang('en')">English</button>
  <button class="lang-btn" onclick="setLang('fil')">Filipino</button>
  <button class="lang-btn" onclick="setLang('ar')">عربي</button>
</div>

<!-- STORY -->
<div class="section">
  <h2 class="section-title">
    <span data-lang="en">Our <span style="color:var(--sky)">Story</span></span>
    <span data-lang="fil">Ang Aming <span style="color:var(--sky)">Kwento</span></span>
    <span data-lang="ar">قصتنا</span>
  </h2>
  <div class="divider"></div>
  <div class="story-text">
    <p data-lang="en">Every day, millions of Filipinos wake up without knowing if they'll have enough to eat, afford medicine, or keep their children in school. But the Filipino spirit is <strong>unbreakable</strong> — they help each other survive, share what little they have, and smile through every storm.</p>
    <p data-lang="en">Today, we ask the world to extend a hand. Your donation — no matter how small — can pay for medicine, a doctor visit, a school uniform, or a meal for a family in need. <strong>Together, we are stronger.</strong></p>
    <p data-lang="fil">Araw-araw, milyun-milyong Pilipino ang nagigising nang hindi alam kung may makakain ba sila, makakabili ng gamot, o mapanatili ang kanilang mga anak sa paaralan. Ngunit ang diwa ng Pilipino ay <strong>hindi mababali</strong> — nagtutulungan sila para mabuhay.</p>
    <p data-lang="fil">Ngayon, hinihiling namin sa mundo na mag-abot ng kamay. Ang iyong donasyon — gaano man kaliit — ay makakatulong sa gamot, doktor, uniporme sa paaralan, o pagkain para sa isang pamilya. <strong>Magkasama, mas malakas tayo.</strong></p>
    <p data-lang="ar">كل يوم، يستيقظ ملايين الفلبينيين دون أن يعرفوا إن كان بإمكانهم شراء الطعام، أو الدواء، أو إبقاء أطفالهم في المدرسة. لكن روح الفلبيني <strong>لا تُكسر</strong> — يتعاونون للبقاء ويتشاركون القليل الذي يملكونه.</p>
    <p data-lang="ar">اليوم، نطلب من العالم أن يمد يد العون. تبرعك — مهما كان صغيراً — يمكنه دفع ثمن دواء، أو زيارة طبية، أو زي مدرسي، أو وجبة لعائلة محتاجة. <strong>معاً، نحن أقوى.</strong></p>
  </div>
</div>

<!-- GOALS -->
<div class="section" style="padding-top:0">
  <h2 class="section-title">
    <span data-lang="en">Two <span style="color:var(--sky)">Goals</span>, One Heart</span>
    <span data-lang="fil">Dalawang <span style="color:var(--sky)">Layunin</span>, Isang Puso</span>
    <span data-lang="ar">هدفان، قلبٌ واحد</span>
  </h2>
  <div class="divider"></div>
  <div class="goals-grid">
    <div class="goal-card">
      <div class="goal-icon">🏥</div>
      <div class="goal-title">
        <span data-lang="en">Medical & Health</span>
        <span data-lang="fil">Medikal at Kalusugan</span>
        <span data-lang="ar">الرعاية الصحية</span>
      </div>
      <p class="goal-desc">
        <span data-lang="en">Medicine, checkups, and care for elderly and families who cannot afford it.</span>
        <span data-lang="fil">Gamot, check-up, at pag-aalaga para sa mga matatanda at pamilyang hindi kayang gumastos.</span>
        <span data-lang="ar">أدوية وفحوصات ورعاية للمسنين والعائلات التي لا تستطيع تحمّل التكاليف.</span>
      </p>
      <div class="progress-wrap">
        <div class="progress-label">
          <span data-lang="en">Raised</span><span data-lang="fil">Nakolekta</span><span data-lang="ar">تم جمع</span>
          <span>$0 / $10,000</span>
        </div>
        <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:0%" id="bar1"></div></div>
      </div>
      <div class="progress-amount">$0 <span style="font-size:0.8rem;color:var(--gray)">raised</span></div>
      <div class="progress-need">
        <span data-lang="en">$10,000 still needed</span>
        <span data-lang="fil">$10,000 pa ang kailangan</span>
        <span data-lang="ar">لا يزال مطلوباً $10,000</span>
      </div>
    </div>
    <div class="goal-card children">
      <div class="goal-icon">📚</div>
      <div class="goal-title">
        <span data-lang="en">Children's Education</span>
        <span data-lang="fil">Edukasyon ng mga Bata</span>
        <span data-lang="ar">تعليم الأطفال</span>
      </div>
      <p class="goal-desc">
        <span data-lang="en">School supplies, uniforms, and support for children who learn in difficult conditions.</span>
        <span data-lang="fil">Mga kagamitan sa paaralan, uniporme, at suporta para sa mga batang nag-aaral sa mahirap na kondisyon.</span>
        <span data-lang="ar">لوازم مدرسية وزي موحد ودعم للأطفال الذين يتعلمون في ظروف صعبة.</span>
      </p>
      <div class="progress-wrap">
        <div class="progress-label">
          <span data-lang="en">Raised</span><span data-lang="fil">Nakolekta</span><span data-lang="ar">تم جمع</span>
          <span>$0 / $10,000</span>
        </div>
        <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:0%" id="bar2"></div></div>
      </div>
      <div class="progress-amount">$0 <span style="font-size:0.8rem;color:var(--gray)">raised</span></div>
      <div class="progress-need">
        <span data-lang="en">$10,000 still needed</span>
        <span data-lang="fil">$10,000 pa ang kailangan</span>
        <span data-lang="ar">لا يزال مطلوباً $10,000</span>
      </div>
    </div>
  </div>
</div>

<!-- DONATE -->
<div class="donate-section">
  <div class="donate-inner">
    <h2>
      <span data-lang="en">Donate Now 🙏</span>
      <span data-lang="fil">Mag-Donate Ngayon 🙏</span>
      <span data-lang="ar">تبرع الآن 🙏</span>
    </h2>
    <p>
      <span data-lang="en">Choose a goal and an amount. Every dollar makes a real difference.</span>
      <span data-lang="fil">Pumili ng layunin at halaga. Bawat dolyar ay may tunay na pagbabago.</span>
      <span data-lang="ar">اختر هدفاً ومبلغاً. كل دولار يُحدث فرقاً حقيقياً.</span>
    </p>
    <div class="goal-select">
      <button class="goal-select-btn active" onclick="selectGoal(this,'health')" id="gBtn1">
        <span data-lang="en">🏥 Medical & Health</span>
        <span data-lang="fil">🏥 Medikal</span>
        <span data-lang="ar">🏥 الصحة</span>
      </button>
      <button class="goal-select-btn" onclick="selectGoal(this,'edu')" id="gBtn2">
        <span data-lang="en">📚 Children's Education</span>
        <span data-lang="fil">📚 Edukasyon</span>
        <span data-lang="ar">📚 تعليم الأطفال</span>
      </button>
    </div>
    <div class="amount-grid">
      <button class="amount-btn" onclick="selectAmt(this,5)">$5</button>
      <button class="amount-btn" onclick="selectAmt(this,10)">$10</button>
      <button class="amount-btn" onclick="selectAmt(this,25)">$25</button>
      <button class="amount-btn" onclick="selectAmt(this,50)">$50</button>
      <button class="amount-btn" onclick="selectAmt(this,100)">$100</button>
    </div>
    <div class="custom-amount">
      <span style="color:rgba(255,255,255,0.7);font-weight:600;">$</span>
      <input class="custom-input" type="number" id="customAmt" placeholder="Custom amount" oninput="setCustom(this.value)">
    </div>
    <button class="donate-btn" onclick="doDonate()">
      <span data-lang="en">Donate via PayPal</span>
      <span data-lang="fil">Mag-Donate sa PayPal</span>
      <span data-lang="ar">تبرع عبر باي بال</span>
    </button>
    <p class="paypal-note">
      <span data-lang="en">🔒 Secure payment. You'll be redirected to PayPal. Your donation goes to "Kamay sa Kamay".</span>
      <span data-lang="fil">🔒 Ligtas ang bayad. Ire-redirect kayo sa PayPal. Ang donasyon ay para sa "Kamay sa Kamay".</span>
      <span data-lang="ar">🔒 دفع آمن. ستُحوَّل إلى PayPal. تبرعك يذهب لـ"Kamay sa Kamay".</span>
    </p>
  </div>
</div>

<!-- GALLERY -->
<div class="section">
  <h2 class="section-title">
    <span data-lang="en">Real <span style="color:var(--sky)">Impact</span></span>
    <span data-lang="fil">Tunay na <span style="color:var(--sky)">Epekto</span></span>
    <span data-lang="ar">أثرٌ حقيقي</span>
  </h2>
  <div class="divider"></div>
  <div class="gallery">
    <img src="data:image/jpeg;base64," alt="Kamay sa Kamay community work" loading="lazy">
    <img src="data:image/jpeg;base64," alt="Kamay sa Kamay community work" loading="lazy">
    <img src="data:image/jpeg;base64," alt="Kamay sa Kamay community work" loading="lazy">
